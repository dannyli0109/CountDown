 277:src/main.c    ****             SaveSettings();
 278:src/main.c    ****         }
 279:src/main.c    ****     } else if (timer.state == TIMER_FINISHED) {
 280:src/main.c    ****         // ń╗ōµØ¤ÕÉÄĶĮ¼ÕŖ©µø▓µ¤äÕöżķåÆ’╝īÕø×Õł░ READY ńŖČµĆü’╝łõ┐ØńĢÖõĖŖµ¼ĪńÜäµŚČķĢ┐’╝ē
 281:src/main.c    ****         if (pd->system->getCrankChange() != 0.0f) {
