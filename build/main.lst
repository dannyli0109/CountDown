 194:src/main.c    **** // 画一个数字卡片，两段式翻牌动画（用完整数字图裁剪出上下半）
 195:src/main.c    **** static void DrawDigit(int x, int y, char value, char prev, float progress)
 196:src/main.c    **** {
 197:src/main.c    ****     int d = value - '0';
 198:src/main.c    ****     int p = prev - '0';
 199:src/main.c    ****     if (d < 0 || d > 9) return;
 200:src/main.c    ****     if (p < 0 || p > 9) p = d;
 201:src/main.c    **** 
 202:src/main.c    ****     float s = DIGIT_SCALE;
 203:src/main.c    ****     int cw = (int)(cardW * s);
 204:src/main.c    ****     int topH = (int)(halfH * s);
 205:src/main.c    **** 
 206:src/main.c    ****     // 透明像素显示为白色：先铺白底
 207:src/main.c    ****     pd->graphics->fillRect(x, y, cw, topH * 2, kColorWhite);
 208:src/main.c    **** 
 209:src/main.c    ****     // 底层（盖板下面露出的部分）：新的上半 + 旧的下半
 210:src/main.c    ****     pd->graphics->setClipRect(x, y, cw, topH);
 211:src/main.c    ****     pd->graphics->drawScaledBitmap(numBmp[d], x, y, s, s);
 212:src/main.c    ****     pd->graphics->setClipRect(x, y + topH, cw, topH);
 213:src/main.c    ****     pd->graphics->drawScaledBitmap(numBmp[p], x, y, s, s);
 214:src/main.c    **** 
 215:src/main.c    ****     if (progress < 0.5f) {
 216:src/main.c    ****         // 第一阶段：旧的上半从中线往下折
 217:src/main.c    ****         float fold = 1.0f - progress / 0.5f;   // 1..0
 218:src/main.c    ****         int h = (int)(topH * fold);
 219:src/main.c    ****         int drawY = y + topH - h;
 220:src/main.c    ****         pd->graphics->setClipRect(x, drawY, cw, h);
 221:src/main.c    ****         pd->graphics->drawScaledBitmap(numBmp[p], x, drawY, s, s * fold);
 222:src/main.c    ****     } else {
 223:src/main.c    ****         // 第二阶段：新的下半从中线往下展开
 224:src/main.c    ****         float grow = (progress - 0.5f) / 0.5f;  // 0..1
 225:src/main.c    ****         int h = (int)(topH * grow);
 226:src/main.c    ****         int drawY = y + topH - h;
 227:src/main.c    ****         pd->graphics->setClipRect(x, y + topH, cw, h);
 228:src/main.c    ****         pd->graphics->drawScaledBitmap(numBmp[d], x, drawY, s, s * grow);
 229:src/main.c    ****     }
 230:src/main.c    **** 
 231:src/main.c    ****     pd->graphics->clearClipRect();
 232:src/main.c    **** }
