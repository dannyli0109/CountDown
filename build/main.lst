 240:src/main.c    ****     if (timer.state == TIMER_READY) {
 241:src/main.c    ****         // õĖŖ/õĖŗµ¢╣ÕÉæķö«Õ£©ķóäĶ«ŠµŚČķĢ┐õ╣ŗķŚ┤ÕłćµŹó’╝łµŚĀńÄ»ń╗Ģ’╝ē
 242:src/main.c    ****         if (pushed & (kButtonUp | kButtonDown)) {
ARM GAS  /var/folders/ym/cl7zt4994p5_9n084fng6gl80000gn/T//ccxpWZpc.s 			page 12


 243:src/main.c    ****             // µēŠÕł░ÕĮōÕēŹ time Õ»╣Õ║öµł¢µ£ĆµÄźĶ┐æńÜäķóäĶ«ŠõĖŗµĀć
 244:src/main.c    ****             int idx = 0;
 245:src/main.c    ****             for (int i = 0; i < PRESET_COUNT; i++) {
 246:src/main.c    ****                 if (timePresets[i] <= time) idx = i;
 247:src/main.c    ****             }
 248:src/main.c    ****             if (pushed & kButtonUp) {
 249:src/main.c    ****                 if (idx < PRESET_COUNT - 1) idx++;
 250:src/main.c    ****             } else {
 251:src/main.c    ****                 if (idx > 0) idx--;
 252:src/main.c    ****             }
 253:src/main.c    ****             time = timePresets[idx];
 254:src/main.c    ****             Timer_Init(&timer, time * 60);
 255:src/main.c    ****             crankOffset = 0.0f;
 256:src/main.c    ****             SaveSettings();
 257:src/main.c    ****         }
 258:src/main.c    **** 
 259:src/main.c    ****         crankOffset += pd->system->getCrankChange();
 260:src/main.c    ****         if (fabsf(crankOffset) > 30.0f) {
 261:src/main.c    ****             if (crankOffset > 0) {
 262:src/main.c    ****                 time++;
 263:src/main.c    ****             } else {
 264:src/main.c    ****                 time--;
 265:src/main.c    ****             }
 266:src/main.c    **** 
