 213:src/main.c    **** 
 214:src/main.c    **** // 画一个数字卡片，两段式翻牌动画（边框 + 数字一起折叠）
 215:src/main.c    **** // dir = 1 向下翻（倒数）；dir = -1 向上翻（增加时间）
 216:src/main.c    **** static void DrawDigit(int x, int y, char value, char prev, float progress, int dir)
 217:src/main.c    **** {
 218:src/main.c    ****     int d = value - '0';
 219:src/main.c    ****     int p = prev - '0';
 220:src/main.c    ****     if (d < 0 || d > 9) return;
 221:src/main.c    ****     if (p < 0 || p > 9) p = d;
 222:src/main.c    **** 
 223:src/main.c    ****     float s = DIGIT_SCALE;
 224:src/main.c    ****     int cw = (int)(cardW * s);
 225:src/main.c    ****     int topH = (int)(halfH * s);
 226:src/main.c    **** 
 227:src/main.c    ****     // 透明像素显示为白色：先铺白底
 228:src/main.c    ****     pd->graphics->fillRect(x, y, cw, topH * 2, kColorWhite);
 229:src/main.c    **** 
 230:src/main.c    ****     if (dir < 0) {
 231:src/main.c    ****         // 向上翻：底层是旧的上半 + 新的下半
 232:src/main.c    ****         DrawCard(p, x, y, s, s, x, y, cw, topH);
 233:src/main.c    ****         DrawCard(d, x, y, s, s, x, y + topH, cw, topH);
 234:src/main.c    **** 
 235:src/main.c    ****         if (progress < 0.5f) {
 236:src/main.c    ****             // 第一阶段：旧的下半从中线往上折
 237:src/main.c    ****             float fold = 1.0f - progress / 0.5f;   // 1..0
 238:src/main.c    ****             int h = (int)(topH * fold);
 239:src/main.c    ****             int drawY = y + topH - h;
 240:src/main.c    ****             DrawCard(p, x, drawY, s, s * fold, x, y + topH, cw, h);
 241:src/main.c    ****         } else {
 242:src/main.c    ****             // 第二阶段：新的上半从中线往上展开
 243:src/main.c    ****             float grow = (progress - 0.5f) / 0.5f;  // 0..1
 244:src/main.c    ****             int h = (int)(topH * grow);
 245:src/main.c    ****             int drawY = y + topH - h;
ARM GAS  /var/folders/ym/cl7zt4994p5_9n084fng6gl80000gn/T//ccsywezQ.s 			page 10


 246:src/main.c    ****             DrawCard(d, x, drawY, s, s * grow, x, y + topH - h, cw, h);
 247:src/main.c    ****         }
 248:src/main.c    ****     } else {
 249:src/main.c    ****         // 向下翻：底层是新的上半 + 旧的下半
 250:src/main.c    ****         DrawCard(d, x, y, s, s, x, y, cw, topH);
 251:src/main.c    ****         DrawCard(p, x, y, s, s, x, y + topH, cw, topH);
 252:src/main.c    **** 
 253:src/main.c    ****         if (progress < 0.5f) {
 254:src/main.c    ****             // 第一阶段：旧的上半从中线往下折
 255:src/main.c    ****             float fold = 1.0f - progress / 0.5f;   // 1..0
 256:src/main.c    ****             int h = (int)(topH * fold);
 257:src/main.c    ****             int drawY = y + topH - h;
 258:src/main.c    ****             DrawCard(p, x, drawY, s, s * fold, x, drawY, cw, h);
 259:src/main.c    ****         } else {
 260:src/main.c    ****             // 第二阶段：新的下半从中线往下展开
 261:src/main.c    ****             float grow = (progress - 0.5f) / 0.5f;  // 0..1
 262:src/main.c    ****             int h = (int)(topH * grow);
 263:src/main.c    ****             int drawY = y + topH - h;
 264:src/main.c    ****             DrawCard(d, x, drawY, s, s * grow, x, y + topH, cw, h);
 265:src/main.c    ****         }
 266:src/main.c    ****     }
 267:src/main.c    **** 
 268:src/main.c    ****     pd->graphics->clearClipRect();
 269:src/main.c    **** }
 270:src/main.c    **** 
 271:src/main.c    **** // 画 MM:SS 翻牌时钟
 272:src/main.c    **** static void DrawClock(void)
 273:src/main.c    **** {
 274:src/main.c    ****     pd->graphics->setDrawMode(kDrawModeCopy);
 275:src/main.c    **** 
 276:src/main.c    ****     int cw = (int)(cardW * DIGIT_SCALE);
 277:src/main.c    ****     int ch = (int)(halfH * DIGIT_SCALE) * 2;
 278:src/main.c    ****     int gap = 8;
 279:src/main.c    ****     int colonW = 20;
 280:src/main.c    ****     int totalW = DIGIT_COUNT * cw + 3 * gap + colonW;
 281:src/main.c    ****     int startX = (400 - totalW) / 2;
 282:src/main.c    ****     int y = (240 - ch) / 2;
 283:src/main.c    **** 
 284:src/main.c    ****     int x = startX;
 285:src/main.c    ****     for (int i = 0; i < DIGIT_COUNT; i++) {
 286:src/main.c    ****         DrawDigit(x, y, digits[i].value, digits[i].prev, digits[i].progress, digits[i].dir);
 287:src/main.c    ****         x += cw + gap;
 288:src/main.c    ****         if (i == 1) {
 289:src/main.c    ****             float cs = (float)ch / 104.0f;
 290:src/main.c    ****             int colonImgW = (int)(18 * cs);
 291:src/main.c    ****             x -= gap;
 292:src/main.c    ****             pd->graphics->drawScaledBitmap(colonBmp, x + (colonW - colonImgW) / 2, y, cs, cs);
 293:src/main.c    ****             x += colonW;
 294:src/main.c    ****         }
 295:src/main.c    ****     }
 296:src/main.c    **** }
